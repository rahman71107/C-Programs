#include <stdio.h>

int main() {
    int num1,num2,temp;
    printf("Enter your 1st number: " );
    scanf("%d",&num1);
    printf("Enter your 2nd number: " );
    scanf("%d",&num2);
    printf("Before Swapping: %d %d\n",num1,num2);
    temp=num1;
    num1=num2;
    num2=temp;
    printf("After Swapping: %d %d\n",num1,num2);
    return 0;
}
