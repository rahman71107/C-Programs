#include <stdio.h>
int fact(int a);
int main() {
    int num;
    int result;
    printf("Enter a Number: ");
    scanf("%d",&num);
    result=fact(num);
    printf("The Factorial of the number is: %d\n",result);
    return 0;
}
int fact(int a){
    int result;
    if(a<=0){
        return 1;
    }
    else{
        result=a*fact(a-1);
        return result;
    }
}
