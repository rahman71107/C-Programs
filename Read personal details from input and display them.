#include <stdio.h>
struct details{
    char name[30];
    int age;
    char address[50];
};
int main(){
    struct details d;
    printf("Enter your Name: ");
    fgets(d.name,sizeof(d.name),stdin);
    printf("Please enter your age: ");
    scanf("%d",&d.age);
    printf("Please enter your address: ");
    scanf("%s",&d.address);
    printf("\n");
    printf("Name: %s",d.name);
    printf("Age: %d\n",d.age);
    printf("Address: %s",d.address);
    return 0;
}
