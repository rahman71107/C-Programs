#include <stdio.h>

int main() {
    int num;
    char msg[50];
    printf("Enter the Message here: ");
    fgets(msg,sizeof(msg),stdin);
    printf("Enter how many times you want to print that message: ");
    scanf("%d",&num);
    for(int i=0;i<num;i++){
        printf("%s\n",msg);
    }
    return 0;
}
