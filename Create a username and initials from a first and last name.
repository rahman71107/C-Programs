#include <stdio.h>
#include<ctype.h>
#include<string.h>
int main() {
    int count=1;
    char name[30];
    char initials[5];
    printf("Enter your name: ");
    fgets(name,sizeof(name),stdin);
    if(!isspace(name[0])&&name[0]!='\0')
    {
        initials[0]=name[0];
    }
    int length=strlen(name);
    for(int i=1;i<length-1;i++){
        if(isspace(name[i])){
          if(name[i+1]!='0'&&name[i+1]!='\n'&&name[i+1]!='\t'&&!isspace(name[i+1])){
              initials[count]=name[i+1];
              count++;
            
              if(count>=4)
                break;
            }
        }
    }
    initials[count]='\0';
    printf("The Initials : %s",initials);
    return 0;
}
